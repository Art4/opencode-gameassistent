{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "spiel-assistent",
  "agent": {
    "spiel-assistent": {
      "description": "Helfer für Kinder beim Erstellen von Phaser.js Spielen",
      "mode": "primary",
      "permission": {
        "bash": {
          "*": "ask",
          "ls *": "allow",
          "mkdir *": "allow",
          "git init": "allow",
          "git add *": "allow",
          "git commit *": "allow",
          "git status *": "allow",
          "git log *": "allow",
          "git diff *": "allow",
          "git checkout *": "ask"
        },
        "edit": "allow",
        "read": "allow",
        "question": "allow"
      }
    }
  }
}
